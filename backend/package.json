{
  "type": "module",
  "name": "backend",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_OPTIONS=--max-old-space-size=16384 vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=html",
    "test:jest": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --coverage --runInBand --forceExit --testTimeout=30000",
    "security:audit": "node scripts/security-audit.js",
    "audit": "npm audit && npm run security:audit",
    "load-test": "node scripts/load-test.js",
    "load-test:heavy": "node scripts/load-test.js --users 50 --duration 60 --rps 5"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@sentry/node": "^10.30.0",
    "@supabase/supabase-js": "^2.86.0",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.1.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "docx": "^9.5.1",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "fs-extra": "^11.3.2",
    "google-auth-library": "^10.5.0",
    "googleapis": "^166.0.0",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "html-docx-js": "^0.3.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.10",
    "openai": "^6.9.0",
    "pdf-parse": "^2.4.5",
    "pdf2json": "^4.0.0",
    "pdfjs-dist": "^5.4.394",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "puppeteer": "^24.29.1",
    "resend": "^6.5.2",
    "svix": "^1.82.0",
    "validator": "^13.15.23",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.15",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0",
    "vitest": "^4.0.15"
  }
}
